    a                   fno:Mapping ;
    fno:function		idlab-fn:stringContainsOtherString;
    fno:implementation	idlab-fn-m:idLabFunctions;
    fno:methodMapping   [ a fnom:StringMethodMapping ; fnom:method-name "stringContainsOtherString" ] .

