@prefix fno:     <https://w3id.org/function/ontology#> .
@prefix fnoi:    <https://w3id.org/function/vocabulary/implementation#> .
@prefix fnom:    <https://w3id.org/function/vocabulary/mapping#> .
@prefix grel:    <http://users.ugent.be/~bjdmeest/function/grel.ttl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

#
# GREL function descriptions for RML-FNML conformance tests.
#
# Declares each grel function as fno:Function with proper fno:expects / fno:returns
# so FnoDescriptionProvider can discover them.  The fno:predicate on each parameter
# matches the IRI used as rml:parameter in the test-case mappings.
#
# Also declares an fno:Mapping for grel:length which maps to the same Java
# implementation as grel:string_length in grel_java_mapping.ttl.  The test cases
# use the short IRI grel:length, while the JAR mapping uses grel:string_length.
#

# --- Parameters ---------------------------------------------------------

grel:_valueParam
    a             fno:Parameter ;
    fno:predicate grel:valueParam ;
    fno:type      xsd:string ;
    fno:required  "true"^^xsd:boolean .

grel:_p_int_i_from
    a             fno:Parameter ;
    fno:predicate grel:p_int_i_from ;
    fno:type      xsd:integer ;
    fno:required  "false"^^xsd:boolean .

grel:_p_int_i_to
    a             fno:Parameter ;
    fno:predicate grel:p_int_i_to ;
    fno:type      xsd:integer ;
    fno:required  "false"^^xsd:boolean .

grel:_modeParam
    a             fno:Parameter ;
    fno:predicate grel:modeParam ;
    fno:type      xsd:string ;
    fno:required  "true"^^xsd:boolean .

grel:_param_find
    a             fno:Parameter ;
    fno:predicate grel:param_find ;
    fno:type      xsd:string ;
    fno:required  "true"^^xsd:boolean .

grel:_param_replace
    a             fno:Parameter ;
    fno:predicate grel:param_replace ;
    fno:type      xsd:string ;
    fno:required  "true"^^xsd:boolean .

# --- Outputs ------------------------------------------------------------

grel:_stringOut
    a             fno:Output ;
    fno:predicate grel:stringOut ;
    fno:type      xsd:string .

grel:_intOut
    a             fno:Output ;
    fno:predicate grel:intOut ;
    fno:type      xsd:integer .

# --- Functions ----------------------------------------------------------

grel:toUpperCase
    a           fno:Function ;
    fno:name    "toUpperCase" ;
    fno:expects ( grel:_valueParam ) ;
    fno:returns ( grel:_stringOut ) .

grel:toLowerCase
    a           fno:Function ;
    fno:name    "toLowerCase" ;
    fno:expects ( grel:_valueParam ) ;
    fno:returns ( grel:_stringOut ) .

grel:length
    a           fno:Function ;
    fno:name    "length" ;
    fno:expects ( grel:_valueParam ) ;
    fno:returns ( grel:_intOut ) .

grel:string_substring
    a           fno:Function ;
    fno:name    "substring" ;
    fno:expects ( grel:_valueParam grel:_p_int_i_from ) ;
    fno:returns ( grel:_stringOut ) .

grel:escape
    a           fno:Function ;
    fno:name    "escape" ;
    fno:expects ( grel:_valueParam grel:_modeParam ) ;
    fno:returns ( grel:_stringOut ) .

grel:string_replace
    a           fno:Function ;
    fno:name    "replace" ;
    fno:expects ( grel:_valueParam grel:_param_find grel:_param_replace ) ;
    fno:returns ( grel:_stringOut ) .

# --- Mapping for grel:length alias ----------------------------------------
# The test cases use grel:length but grel_java_mapping.ttl binds
# grel:string_length.  This mapping allows FnoDescriptionProvider to
# resolve grel:length to the same Java implementation.

<http://fno.io/grel/rmlmapping#lengthAliasMapping>
    a                    fno:Mapping ;
    fno:function         grel:length ;
    fno:implementation   [ a fnoi:JavaClass ; fnoi:class-name "io.fno.grel.StringFunctions" ] ;
    fno:methodMapping    [ a fnom:StringMethodMapping ; fnom:method-name "length" ] .
