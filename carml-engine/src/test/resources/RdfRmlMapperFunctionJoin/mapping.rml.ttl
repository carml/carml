@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml-old: <http://semweb.mmlab.be/ns/rml#> .
@prefix rml: <http://w3id.org/rml/> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix ex: <http://example.com/ns#> .
@prefix fno: <https://w3id.org/function/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#PersonMapping>
    rml-old:logicalSource [
        rml-old:source "persons.json" ;
        rml-old:referenceFormulation ql:JSONPath ;
        rml-old:iterator "$[*]"
    ] ;
    rr:subjectMap [
        rr:template "http://example.com/person/{id}" ;
        rr:class ex:Person
    ] ;
    rr:predicateObjectMap [
        rr:predicate ex:city ;
        rr:objectMap [
            rr:parentTriplesMap <#CityMapping> ;
            rr:joinCondition [
                rml:childMap <#UpperCaseCityChildMap> ;
                rml:parentMap [ rml-old:reference "name" ]
            ]
        ]
    ] .

<#UpperCaseCityChildMap>
    rml:functionExecution [
        rml:functionMap [ rml:constant ex:toUpperCase ] ;
        rml:input [
            rml:parameterMap [ rml:constant ex:inputParam ] ;
            rml:inputValueMap [ rml-old:reference "city" ]
        ]
    ] .

<#CityMapping>
    rml-old:logicalSource [
        rml-old:source "cities.json" ;
        rml-old:referenceFormulation ql:JSONPath ;
        rml-old:iterator "$[*]"
    ] ;
    rr:subjectMap [
        rr:template "http://example.com/city/{name}" ;
        rr:class ex:City
    ] ;
    rr:predicateObjectMap [
        rr:predicate ex:country ;
        rr:objectMap [ rml-old:reference "country" ]
    ] .
