@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ex: <http://example.com/>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.

<#ItemMapping> a rr:TriplesMap;
  rml:logicalSource [
    rml:source "test19/duplicateExpressionValues.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.items[*]"
  ];

  rr:subjectMap [
    rr:template "http://example.com/item/{id}"
  ];

  rr:predicateObjectMap [
    rr:predicate ex:tag;
    rr:objectMap [
      rml:reference "tags[*]"
    ]
  ].
